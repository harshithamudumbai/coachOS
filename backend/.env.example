# ============================================================
# Dr.Query Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in all values.
# NEVER commit the .env file to version control.
# ============================================================

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (comma-separated for multiple origins)
# CORS will ONLY allow requests from these origins in production.
# Example: https://drquery.vercel.app,https://www.drquery.com
FRONTEND_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=coachos_db
DB_SSL=false

# AI Provider (Groq)
# ⚠️  ROTATION POLICY: Rotate this key every 90 days minimum.
#     Last rotated: YYYY-MM-DD (update this when you rotate)
GROQ_API_KEY=
